{
  "name": "drinks-reviewer",
  "version": "1.0.0",
  "description": "Personal drinks review website",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch --env-file-if-exists=.env server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node --env-file-if-exists=.env server/index.js",
    "preview": "vite preview",
    "test:server": "jest",
    "test:client": "vitest run",
    "test": "npm run test:server && npm run test:client",
    "test:coverage": "vitest run --coverage",
    "posttest:coverage": "node scripts/mark-tests-passed.js client",
    "test:coverage:server": "jest --coverage",
    "posttest:coverage:server": "node scripts/mark-tests-passed.js server",
    "prepare": "node scripts/install-hooks.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.4.0",
    "express": "^4.18.2",
    "google-auth-library": "^10.9.0",
    "mongodb": "^7.5.0",
    "multer": "^2.2.0",
    "react": "^18.2.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.9.1",
    "vite": "^5.2.0",
    "world-atlas": "^2.0.2"
  },
  "overrides": {
    "d3-color": "^3.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitest/coverage-v8": "^1.6.1",
    "concurrently": "^8.2.2",
    "happy-dom": "^20.10.6",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "vitest": "^1.4.0"
  }
}
